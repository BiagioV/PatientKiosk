<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clinical_surface"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/clinical_blue_dark"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/app_subtitle"
            android:textColor="@color/clinical_muted"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:textColor="@color/clinical_error"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/patientSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/patient_identification_title"
                android:textColor="@color/clinical_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/patient_identification_intro"
                android:textColor="@color/clinical_muted"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/patient_code_label"
                android:textColor="@color/clinical_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/patientCodeInput"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="8dp"
                android:hint="@string/patient_code_hint"
                android:importantForAutofill="no"
                android:imeOptions="actionDone"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:maxLength="20"
                android:singleLine="true"
                android:textColor="@color/clinical_text"
                android:textColorHint="@color/clinical_muted"
                android:textSize="22sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/patient_code_help"
                android:textColor="@color/clinical_muted"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:text="@string/patient_privacy_note"
                android:textColor="@color/clinical_blue_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/startButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/primary_button_background"
                android:text="@string/start_button"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selectionSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="22dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/patientSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/clinical_muted"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/questionnaire_selection_title"
                android:textColor="@color/clinical_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/questionnaire_selection_intro"
                android:textColor="@color/clinical_muted"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:text="@string/questionnaire_selection_help"
                android:textColor="@color/clinical_blue_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ListView
                android:id="@+id/questionnaireList"
                android:layout_width="match_parent"
                android:layout_height="460dp"
                android:layout_marginTop="18dp"
                android:choiceMode="singleChoice"
                android:divider="@android:color/transparent"
                android:dividerHeight="12dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/questionSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="22dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/questionnaireTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/clinical_blue_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:layout_marginTop="14dp"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/progressText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/clinical_muted"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/questionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/clinical_text"
                android:textSize="25sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/answersGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/backButton"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="@string/previous_question"
                    android:textSize="18sp" />

                <Space
                    android:layout_width="14dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/nextButton"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:background="@drawable/primary_button_background"
                    android:text="@string/next_question"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="22dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. Risultato"
                android:textColor="@color/clinical_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/resultScoreText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/clinical_blue_dark"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/resultInterpretationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/clinical_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/resultDetailsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/clinical_muted"
                android:textSize="18sp" />

            <Button
                android:id="@+id/changeQuestionnaireButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="22dp"
                android:text="@string/change_questionnaire"
                android:textSize="18sp" />

            <Button
                android:id="@+id/restartButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/primary_button_background"
                android:text="@string/restart"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>