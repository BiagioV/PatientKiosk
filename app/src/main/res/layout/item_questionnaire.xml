<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_background"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/itemTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/clinical_text"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/itemDescriptionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/clinical_muted"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/itemMetaText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/clinical_blue_dark"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
